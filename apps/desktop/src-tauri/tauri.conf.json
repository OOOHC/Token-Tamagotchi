{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Tamagotchi",
  "version": "0.1.0",
  "identifier": "app.token-tamagotchi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Token Tamagotchi",
        "width": 360,
        "height": 640,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
