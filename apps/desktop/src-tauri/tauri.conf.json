{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Tamagotchi",
  "version": "0.1.0",
  "identifier": "app.token-tamagotchi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Token Tamagotchi",
        "width": 320,
        "height": 420,
        "resizable": false,
        "transparent": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

